#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_TASKS 100

typedef struct {
    int id;
    char title[50];
    int priority; // 1=Low, 2=Medium, 3=High
    int done;
    int active;
} Task;

Task tasks[MAX_TASKS];
int taskCount = 0;
int nextId = 1;

// ---------- STACK for Undo ----------
int undoStack[MAX_TASKS];
int top = -1;

void pushUndo(int id) {
    if (top < MAX_TASKS - 1) undoStack[++top] = id;
}
int popUndo() {
    if (top >= 0) return undoStack[top--];
    return -1;
}

// ---------- PRIORITY QUEUE (MAX HEAP) ----------
int heap[MAX_TASKS];
int heapSize = 0;

void swap(int *a, int *b) {
    int t = *a; *a = *b; *b = t;
}

int comparePriority(int i, int j) {
    return tasks[i].priority > tasks[j].priority;
}

void heapifyUp(int idx) {
    while (idx > 0) {
        int parent = (idx - 1) / 2;
        if (comparePriority(heap[idx], heap[parent])) {
            swap(&heap[idx], &heap[parent]);
            idx = parent;
        } else break;
    }
}

void heapifyDown(int idx) {
    while (1) {
        int left = 2 * idx + 1, right = 2 * idx + 2, largest = idx;
        if (left < heapSize && comparePriority(heap[left], heap[largest]))
            largest = left;
        if (right < heapSize && comparePriority(heap[right], heap[largest]))
            largest = right;
        if (largest != idx) {
            swap(&heap[idx], &heap[largest]);
            idx = largest;
        } else break;
    }
}

void insertHeap(int index) {
    heap[heapSize] = index;
    heapifyUp(heapSize);
    heapSize++;
}

int extractMax() {
    if (heapSize == 0) return -1;
    int topIndex = heap[0];
    heap[0] = heap[--heapSize];
    heapifyDown(0);
    return topIndex;
}

// ---------- CORE OPERATIONS ----------
void addTask() {
    if (taskCount >= MAX_TASKS) {
        printf("Task limit reached!\n");
        return;
    }

    Task t;
    t.id = nextId++;
    printf("Enter title: ");
    fgets(t.title, sizeof(t.title), stdin);
    t.title[strcspn(t.title, "\n")] = 0;

    printf("Priority (1=Low, 2=Medium, 3=High): ");
    scanf("%d", &t.priority);
    getchar();

    t.done = 0;
    t.active = 1;

    tasks[taskCount] = t;
    insertHeap(taskCount);
    taskCount++;

    printf("Task added with ID %d!\n", t.id);
}

void listTasks() {
    printf("\n--- All Tasks ---\n");
    for (int i = 0; i < taskCount; i++) {
        if (!tasks[i].active) continue;
        printf("[%d] %-25s | Priority: %d | %s\n",
               tasks[i].id,
               tasks[i].title,
               tasks[i].priority,
               tasks[i].done ? "DONE" : "PENDING");
    }
}

void viewByPriority() {
    printf("\n--- Tasks by Priority ---\n");
    if (heapSize == 0) {
        printf("(No tasks)\n");
        return;
    }
    for (int i = 0; i < heapSize; i++) {
        int idx = heap[i];
        if (tasks[idx].active && !tasks[idx].done)
            printf("[%d] %-25s | Priority: %d\n",
                   tasks[idx].id, tasks[idx].title, tasks[idx].priority);
    }
}

void completeTask() {
    int id;
    printf("Enter task ID to mark COMPLETE: ");
    scanf("%d", &id);
    getchar();

    for (int i = 0; i < taskCount; i++) {
        if (tasks[i].id == id && tasks[i].active) {
            if (tasks[i].done) {
                printf("Already completed!\n");
                return;
            }
            tasks[i].done = 1;
            pushUndo(id);
            printf("Task %d marked as DONE!\n", id);
            return;
        }
    }
    printf("Task not found!\n");
}

void undoLastComplete() {
    int id = popUndo();
    if (id == -1) {
        printf("Nothing to undo!\n");
        return;
    }
    for (int i = 0; i < taskCount; i++) {
        if (tasks[i].id == id) {
            tasks[i].done = 0;
            printf("Undo: Task %d restored to PENDING!\n", id);
            return;
        }
    }
}

